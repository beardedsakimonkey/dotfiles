custom-shader = text-gradient.glsl
custom-shader = party_sparks.glsl
custom-shader = cursor_blaze_tapered.glsl
# custom-shader = scanlines.glsl
custom-shader-animation = false

# adjust-underline-position = -3
# adjust-cell-height = -20%

###### one half
theme = one half dark
font-family = berkeley mono
font-size = 14

###### unokai
# theme = Monokai Classic
# font-family = cascadia code
# font-size = 15

###### wave
# theme = kanagawa wave
# font-family = triplicate t4
# font-size = 14

font-thicken = true
# font-thicken-strength = 0

title = " "
macos-titlebar-proxy-icon = hidden
# macos-titlebar-style = tabs
window-decoration = none
link-previews = osc8
notify-on-command-finish = unfocused

font-feature = -calt, -liga, -dlig
cursor-style = block
shell-integration-features = no-cursor
unfocused-split-opacity = 0.8
mouse-scroll-multiplier = precision:1,discrete:1

window-decoration = true
confirm-close-surface = false
mouse-hide-while-typing = true

keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right

keybind = cmd+enter=new_split:right
keybind = cmd+shift+enter=new_split:down

keybind = cmd+]=next_tab
keybind = cmd+[=previous_tab

# cmd+o (open selected path in Neovim) is handled by Hammerspoon, since Ghostty
# has no action to open a selected path / run a command. See ~/.hammerspoon/init.lua.
